# Backend environment variables
# For local development, place a .env file in Backend/ and do not commit it.
DATABASE_URL=mssql+pyodbc://<username>:<password>@<server>.database.windows.net/<database>?driver=ODBC+Driver+17+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
JWT_SECRET_KEY=replace-with-a-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTHORIZED_EMAIL_DOMAIN=iith.ac.in
# Optional: use Azure Key Vault for production secret storage
AZURE_KEY_VAULT_NAME=<your-key-vault-name>
